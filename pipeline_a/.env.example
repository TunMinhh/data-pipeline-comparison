# =============================================================================
# Pipeline A — environment template
# =============================================================================
# Copy to .env and fill in values:   cp .env.example .env
#
# For a VPS deployment, replace every password with a random string:
#   openssl rand -base64 32
# =============================================================================

# ---- PostgreSQL -------------------------------------------------------------
POSTGRES_USER=admin
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=airflow_db

# ---- Airflow admin login ----------------------------------------------------
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=CHANGE_ME
AIRFLOW_ADMIN_EMAIL=you@example.com
AIRFLOW_ADMIN_FIRSTNAME=First
AIRFLOW_ADMIN_LASTNAME=Last

# ---- MinIO ------------------------------------------------------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CHANGE_ME

# ---- MLflow --> MinIO (must match MINIO_ROOT_* above) -----------------------
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=CHANGE_ME

# ---- PostgreSQL SINK (Gold -> Grafana, host port 5434) ----------------------
PG_SINK_USER=grafana
PG_SINK_PASSWORD=CHANGE_ME
PG_SINK_DB=wellness

# ---- Grafana admin ----------------------------------------------------------
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME

# ---- Kafka KRaft cluster ID -------------------------------------------------
# For a fresh cluster on a new host, generate one:
#   docker run --rm apache/kafka:3.7.0 /opt/kafka/bin/kafka-storage.sh random-uuid
KAFKA_CLUSTER_ID=CHANGE_ME
