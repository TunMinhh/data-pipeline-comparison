# =============================================================================
# Pipeline A — local / VPS secrets & config
# =============================================================================
# This file is gitignored (see .gitignore: *.env, *.env.*).
#
# For local dev the defaults below are fine.
# BEFORE deploying to a VPS, replace every password below with a long random
# string (e.g. `openssl rand -base64 32`).
# =============================================================================

# ---- PostgreSQL (shared: airflow_db + mlflow_db) ----------------------------
POSTGRES_USER=admin
POSTGRES_PASSWORD=pwd12345
POSTGRES_DB=airflow_db

# ---- Airflow admin login (UI: http://<host>:8081) ---------------------------
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=pwd12345
AIRFLOW_ADMIN_EMAIL=tranminhkhang1811@gmail.com
AIRFLOW_ADMIN_FIRSTNAME=Minh
AIRFLOW_ADMIN_LASTNAME=Tran

# ---- MinIO (S3 API :9100, Console :9101) ------------------------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123

# ---- MLflow --> MinIO artifact credentials ----------------------------------
# These MUST match MINIO_ROOT_USER / MINIO_ROOT_PASSWORD above.
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin123

# ---- PostgreSQL SINK (Gold -> Grafana, host port 5434) ----------------------
PG_SINK_USER=grafana
PG_SINK_PASSWORD=grafana123
PG_SINK_DB=wellness

# ---- Grafana admin (UI: http://<host>:3000) ---------------------------------
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin123

# ---- Kafka KRaft cluster ID -------------------------------------------------
# Generate a new one for a fresh cluster: docker run --rm apache/kafka:3.7.0 /opt/kafka/bin/kafka-storage.sh random-uuid
KAFKA_CLUSTER_ID=4L6g3nShT-eMCtK--X86sw
